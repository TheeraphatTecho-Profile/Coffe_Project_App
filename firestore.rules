rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the data
    function isOwner(resourceUserId) {
      return request.auth.uid == resourceUserId;
    }
    
    // Helper function to validate farm data
    function isValidFarmData() {
      return request.resource.data.keys().hasAll([
        'name', 'area', 'province', 'user_id', 'created_at'
      ]) &&
      request.resource.data.name is string &&
      request.resource.data.name.size() > 0 &&
      request.resource.data.name.size() <= 100 &&
      request.resource.data.area is number &&
      request.resource.data.area >= 0 &&
      request.resource.data.area <= 10000 &&
      request.resource.data.province is string &&
      request.resource.data.province.size() > 0 &&
      request.resource.data.user_id is string &&
      request.resource.data.user_id == request.auth.uid;
    }
    
    // Helper function to validate harvest data
    function isValidHarvestData() {
      return request.resource.data.keys().hasAll([
        'farm_id', 'harvest_date', 'weight_kg', 'income', 'shift', 'user_id', 'created_at'
      ]) &&
      request.resource.data.farm_id is string &&
      request.resource.data.farm_id.size() > 0 &&
      request.resource.data.harvest_date is timestamp &&
      request.resource.data.weight_kg is number &&
      request.resource.data.weight_kg > 0 &&
      request.resource.data.weight_kg <= 10000 &&
      request.resource.data.income is number &&
      request.resource.data.income >= 0 &&
      request.resource.data.income <= 1000000 &&
      request.resource.data.shift in ['morning', 'afternoon'] &&
      request.resource.data.user_id is string &&
      request.resource.data.user_id == request.auth.uid;
    }
    
    // Farms collection - users can only access their own farms
    match /farms/{farmId} {
      allow read: if isAuthenticated() && isOwner(resource.data.user_id);
      allow create: if isAuthenticated() && isValidFarmData();
      allow update: if isAuthenticated() && isOwner(resource.data.user_id) && isValidFarmData();
      allow delete: if isAuthenticated() && isOwner(resource.data.user_id);
      allow list: if isAuthenticated();
      
      // Indexes for better performance
      ensure index on (user_id, created_at);
      ensure index on (province, created_at);
    }
    
    // Harvests collection - users can only access their own harvests
    match /harvests/{harvestId} {
      allow read: if isAuthenticated() && isOwner(resource.data.user_id);
      allow create: if isAuthenticated() && isValidHarvestData();
      allow update: if isAuthenticated() && isOwner(resource.data.user_id) && isValidHarvestData();
      allow delete: if isAuthenticated() && isOwner(resource.data.user_id);
      allow list: if isAuthenticated();
      
      // Indexes for better performance
      ensure index on (user_id, harvest_date);
      ensure index on (farm_id, harvest_date);
    }
    
    // Users collection - restricted access
    match /users/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
      
      // User profile validation
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['uid', 'email', 'created_at']) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email is string &&
        request.resource.data.email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }
    
    // Photos collection - user-specific access
    match /photos/{photoId} {
      allow read: if isAuthenticated() && isOwner(resource.data.user_id);
      allow create: if isAuthenticated() && 
        request.resource.data.user_id == request.auth.uid &&
        request.resource.data.type in ['farm', 'harvest', 'disease', 'pest', 'general'] &&
        request.resource.data.url is string &&
        request.resource.data.url.size() > 0;
      allow update: if isAuthenticated() && isOwner(resource.data.user_id);
      allow delete: if isAuthenticated() && isOwner(resource.data.user_id);
      allow list: if isAuthenticated();
    }
    
    // Notifications collection - user-specific access
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && isOwner(resource.data.user_id);
      allow create: if isAuthenticated() && 
        request.resource.data.user_id == request.auth.uid &&
        request.resource.data.type in ['harvest', 'care', 'weather', 'price', 'system'];
      allow update: if isAuthenticated() && isOwner(resource.data.user_id);
      allow delete: if isAuthenticated() && isOwner(resource.data.user_id);
      allow list: if isAuthenticated();
    }
    
    // ========== COMMUNITY FEATURES ==========
    
    // Community Posts - public read, authenticated write
    match /community_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.author_id == request.auth.uid &&
        request.resource.data.author_name is string &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 200 &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 5000 &&
        request.resource.data.post_type in ['question', 'share', 'tips', 'announcement', 'market'];
      allow update: if isAuthenticated() && 
        (isOwner(resource.data.author_id) ||
         resource.data.likes_count == request.resource.data.likes_count + 1 ||
         resource.data.comments_count == request.resource.data.comments_count + 1);
      allow delete: if isAuthenticated() && isOwner(resource.data.author_id);
      allow list: if isAuthenticated();
    }
    
    // Community Comments - public read, authenticated write
    match /community_comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.author_id == request.auth.uid &&
        request.resource.data.post_id is string &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 1000;
      allow update: if isAuthenticated() && 
        (isOwner(resource.data.author_id) ||
         resource.data.likes_count == request.resource.data.likes_count + 1);
      allow delete: if isAuthenticated() && isOwner(resource.data.author_id);
      allow list: if isAuthenticated();
    }
    
    // Community Groups - public read, authenticated create
    match /community_groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.created_by == request.auth.uid;
      allow update: if isAuthenticated() && 
        (isOwner(resource.data.created_by) ||
         resource.data.member_count == request.resource.data.member_count + 1);
      allow delete: if isAuthenticated() && isOwner(resource.data.created_by);
      allow list: if isAuthenticated();
    }
    
    // Community Reports - authenticated create only
    match /community_reports/{reportId} {
      allow create: if isAuthenticated() && 
        request.resource.data.reporter_id == request.auth.uid &&
        request.resource.data.post_id is string &&
        request.resource.data.reason is string;
      allow read, update, delete: if false;
      allow list: if false;
    }
    
    // ========== SOCIAL FEATURES ==========
    
    // Push Tokens - user-specific
    match /push_tokens/{tokenId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create, update: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow list: if false;
    }
    
    // Follows collection
    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.follower_id == request.auth.uid &&
        request.resource.data.following_id is string &&
        request.resource.data.following_id != request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.follower_id == request.auth.uid;
      allow list: if isAuthenticated();
    }
    
    // Conversations - participants only
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participant_ids;
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participant_ids;
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participant_ids;
      allow delete: if isAuthenticated() && 
        request.auth.uid in resource.data.participant_ids;
      allow list: if isAuthenticated();
    }
    
    // Messages - conversation participants only
    match /messages/{messageId} {
      allow read: if isAuthenticated() && 
        resource.data.conversation_id is string;
      allow create: if isAuthenticated() && 
        request.resource.data.sender_id == request.auth.uid &&
        request.resource.data.content is string;
      allow update: if isAuthenticated() && 
        resource.data.sender_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.sender_id == request.auth.uid;
      allow list: if false;
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
